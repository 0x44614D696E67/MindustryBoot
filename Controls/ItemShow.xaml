<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="MindustryBoot.Controls.ItemShow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MindustryBoot.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinHeight="114"
    MaxHeight="114"
    PointerEntered="UserControl_PointerEntered"
    PointerExited="UserControl_PointerExited"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
    </UserControl.Resources>

    <Border
        x:Name="RootBorder"
        RenderTransformOrigin="0.5,0.5"
        Style="{StaticResource CardBorderStyle}">
        <Border.RenderTransform>
            <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>

        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <!--  布局网格：只保留一行，所有内容均位于第一行  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <!--  图标列  -->
                <ColumnDefinition Width="*" />
                <!--  信息列（固定宽度）  -->
                <ColumnDefinition Width="Auto" />
                <!--  作者/下载按钮列  -->
            </Grid.ColumnDefinitions>

            <!--  左侧正方形图标  -->
            <Border
                Grid.Column="0"
                Width="80"
                Height="80"
                Background="{ThemeResource CardBackgroundFillColorSecondary}"
                CornerRadius="4">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="ImageScaleTransform" CenterX="0" CenterY="0" ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Image
                    Width="64"
                    Height="64"
                    Source="{x:Bind _iconSource, Mode=OneWay}"
                    Stretch="Uniform" />
            </Border>

            <!--  右侧信息区域（改为 Grid，便于重叠布局）  -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  标题行  -->
                    <RowDefinition Height="Auto" />
                    <!--  副标题/详细介绍行  -->
                </Grid.RowDefinitions>

                <!--  标题  -->
                <local:AutoRichText
                    Grid.Row="0"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="{x:Bind Title, Mode=OneWay}" />

                <!--  重叠容器：副标题和详细介绍在同一位置  -->
                <Grid Grid.Row="1">
                    <!--  副标题（默认显示）  -->
                    <TextBlock
                        x:Name="SubtitleTextBlock"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Opacity="1"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Subtitle, Mode=OneWay}" />

                    <!--  详细介绍（默认隐藏）  -->
                    <dev:AutoScrollView IsPlaying="True">
                        <RichTextBlock
                            x:Name="DetailTextBlock"
                            DataContext="{x:Bind DetailedDescription, Mode=OneWay}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Opacity="0"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            TextWrapping="Wrap" />
                    </dev:AutoScrollView>
                </Grid>
            </Grid>

            <!--  右下角容器：作者与下载按钮重叠（保持不变）  -->
            <Grid
                Grid.Column="2"
                Margin="8,4,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom">
                <!--  作者名称  -->
                <Grid x:Name="AuthorTranslateGrid" CornerRadius="4">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="AuthorTranslate" Y="0" />
                    </Grid.RenderTransform>
                    <TextBlock
                        x:Name="AuthorTextBlock"
                        Margin="0,0,-1,0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        RenderTransformOrigin="0.5,0.5"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Tag, Mode=OneWay}" />
                </Grid>


                <!--  下载按钮  -->
                <Button
                    x:Name="DownloadButton"
                    Width="56"
                    Height="32"
                    Margin="-4,-64,0,-8"
                    Content="下载"
                    IsHitTestVisible="False"
                    Opacity="0"
                    RenderTransformOrigin="0.5,0.5"
                    Style="{StaticResource AccentButtonStyle}">
                    <Button.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="ButtonTranslate" Y="0" />
                            <ScaleTransform x:Name="ButtonScale" ScaleX="0" ScaleY="0" />
                        </TransformGroup>
                    </Button.RenderTransform>
                </Button>
            </Grid>
        </Grid>

        <!--  视觉状态管理  -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal">
                    <Storyboard>
                        <!--  缩放恢复  -->
                        <DoubleAnimation
                            Storyboard.TargetName="ScaleTransform"
                            Storyboard.TargetProperty="ScaleX"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ScaleTransform"
                            Storyboard.TargetProperty="ScaleY"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!--  图标恢复  -->
                        <!--DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="ScaleX"
                            To="1"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="ScaleY"
                            To="1"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation-->

                        <!--  图标移动  -->
                        <!--DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="CenterY"
                            To="0"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="CenterX"
                            To="0"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation-->

                        <!--  作者恢复原位  -->
                        <DoubleAnimation
                            Storyboard.TargetName="AuthorTranslate"
                            Storyboard.TargetProperty="Y"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="AuthorTextBlock"
                            Storyboard.TargetProperty="Opacity"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!--  下载按钮恢复隐藏  -->
                        <DoubleAnimation
                            Storyboard.TargetName="ButtonTranslate"
                            Storyboard.TargetProperty="Y"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ButtonScale"
                            Storyboard.TargetProperty="ScaleX"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ButtonScale"
                            Storyboard.TargetProperty="ScaleY"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="DownloadButton"
                            Storyboard.TargetProperty="Opacity"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DownloadButton" Storyboard.TargetProperty="IsHitTestVisible">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="False" />
                        </ObjectAnimationUsingKeyFrames>

                        <!--  副标题恢复显示，详细介绍隐藏  -->
                        <DoubleAnimation
                            Storyboard.TargetName="SubtitleTextBlock"
                            Storyboard.TargetProperty="Opacity"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="DetailTextBlock"
                            Storyboard.TargetProperty="Opacity"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </VisualState>

                <VisualState x:Name="PointerOver">
                    <Storyboard>
                        <!--  整体放大  -->
                        <DoubleAnimation
                            Storyboard.TargetName="ScaleTransform"
                            Storyboard.TargetProperty="ScaleX"
                            To="1.05"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <ExponentialEase EasingMode="EaseOut" Exponent="7" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ScaleTransform"
                            Storyboard.TargetProperty="ScaleY"
                            To="1.05"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <ExponentialEase EasingMode="EaseOut" Exponent="7" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <!--  图标的反向缩小  -->
                        <!--DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="ScaleX"
                            To="0.8334"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="ScaleY"
                            To="0.8334"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation-->
                        <!--  图标移动  -->
                        <!--DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="CenterY"
                            To="30"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ImageScaleTransform"
                            Storyboard.TargetProperty="CenterX"
                            To="30"
                            Duration="0:0:0.4">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation-->

                        <!--  作者上移并淡出  -->
                        <DoubleAnimation
                            Storyboard.TargetName="AuthorTranslate"
                            Storyboard.TargetProperty="Y"
                            To="-30"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="AuthorTextBlock"
                            Storyboard.TargetProperty="Opacity"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>


                        <!--  下载按钮上移并淡入  -->
                        <DoubleAnimation
                            Storyboard.TargetName="ButtonTranslate"
                            Storyboard.TargetProperty="Y"
                            To="-30"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ButtonScale"
                            Storyboard.TargetProperty="ScaleX"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="ButtonScale"
                            Storyboard.TargetProperty="ScaleY"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="DownloadButton"
                            Storyboard.TargetProperty="Opacity"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DownloadButton" Storyboard.TargetProperty="IsHitTestVisible">
                            <DiscreteObjectKeyFrame KeyTime="0" Value="True" />
                        </ObjectAnimationUsingKeyFrames>

                        <!--  副标题淡出，详细介绍淡入（平滑替换）  -->
                        <DoubleAnimation
                            Storyboard.TargetName="SubtitleTextBlock"
                            Storyboard.TargetProperty="Opacity"
                            To="0"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation
                            Storyboard.TargetName="DetailTextBlock"
                            Storyboard.TargetProperty="Opacity"
                            To="1"
                            Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseInOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Border>
</UserControl>
