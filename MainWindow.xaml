<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="MindustryBoot.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MindustryBoot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="AppTitleBar"
            Title="{x:Bind dev:ProcessInfoHelper.ProductName}"
            BackRequested="AppTitleBar_BackRequested"
            IsBackButtonVisible="True"
            IsPaneToggleButtonVisible="False"
            Subtitle="{x:Bind dev:ProcessInfoHelper.VersionWithPrefix}">
            <!--  Temporary Fix TitleBar Icon  -->
            <TitleBar.LeftHeader>
                <ImageIcon
                    Width="16"
                    Height="16"
                    Margin="16,0,14,0"
                    Source="ms-appx:///Assets/AppIcon.png" />
            </TitleBar.LeftHeader>
            <TitleBar.RightHeader>
                <Button
                    x:Name="ThemeButton"
                    Height="32"
                    Margin="0,0,4,0"
                    Click="ThemeButton_Click"
                    Content="{dev:FontIcon GlyphCode=E793,
                                           FontSize=16}"
                    Style="{ThemeResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Toggle Theme" />
            </TitleBar.RightHeader>
        </TitleBar>
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Style="{StaticResource NavigationViewStoreStyle}">
            <NavigationView.Header>
                <dev:BreadcrumbNavigator x:Name="BreadCrumbNav" />
            </NavigationView.Header>

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="首页"
                    Icon="{dev:FontIcon Glyph=&#xE80F;}"
                    IsSelected="True"
                    Tag="Home" />
                <NavigationViewItem
                    Content="游戏管理"
                    Icon="{dev:FontIcon Glyph=&#xE912;}"
                    Tag="GameManager" />
                <NavigationViewItem
                    Content="下载"
                    Icon="{dev:FontIcon Glyph=&#xE896;}"
                    Tag="Download" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Content="设置"
                    Icon="{dev:FontIcon Glyph=&#xE713;}"
                    Tag="Settings" />
            </NavigationView.FooterMenuItems>
            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>

