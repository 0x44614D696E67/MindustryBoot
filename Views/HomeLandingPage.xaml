<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MindustryBoot.Views.HomeLandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:MindustryBoot.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MindustryBoot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="400" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <dev:HeaderCarousel
            Grid.Row="0"
            BlurAmount="100"
            IsBlurEnabled="True">
            <dev:HeaderCarousel.Header>
                <TextBlock
                    HorizontalAlignment="Center"
                    CharacterSpacing="48"
                    FontSize="40"
                    FontWeight="Bold"
                    Opacity="0.8"
                    Text="Mindustry Boot"
                    TextAlignment="Center"
                    TextWrapping="Wrap">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0.1" Color="#303030" />
                            <GradientStop Offset="0.3" Color="#4A4A4A" />
                            <GradientStop Offset="0.6" Color="#161515" />
                            <GradientStop Offset="0.9" Color="#303030" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </dev:HeaderCarousel.Header>
            <dev:HeaderCarousel.SecondaryHeader>
                <TextBlock
                    Margin="10,4,10,4"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextAlignment="Center"
                    TextWrapping="Wrap">
                    <Run Text="WinUI 3 驱动的" />
                    <Hyperlink NavigateUri="https://github.com/0x44614D696E67/MindustryBoot">开源</Hyperlink>
                    <Run Text=" Mindustry 启动器！" />
                </TextBlock>
            </dev:HeaderCarousel.SecondaryHeader>
            <dev:HeaderCarouselItem
                Description="自动配置 Java 环境"
                Foreground="{StaticResource DarkTextGradient}"
                Header="Java"
                Id="Java"
                ImageUrl="ms-appx:///Assets/HeaderCarousel/Construction.png" />
            <dev:HeaderCarouselItem
                Description="一站式下载游戏本体"
                Foreground="{StaticResource DarkTextGradient}"
                Header="游戏本体"
                Id="Game"
                ImageUrl="ms-appx:///Assets/HeaderCarousel/Construction.png" />
            <dev:HeaderCarouselItem
                Description="链接 WayZer 地图站"
                Foreground="{StaticResource DarkTextGradient}"
                Header="地图站"
                Id="MapStation"
                ImageUrl="ms-appx:///Assets/HeaderCarousel/Construction.png" />
            <dev:HeaderCarouselItem
                Description="集成 Mod 浏览器"
                Foreground="{StaticResource DarkTextGradient}"
                Header="模组"
                Id="Mod"
                ImageUrl="ms-appx:///Assets/HeaderCarousel/Construction.png" />
            <dev:HeaderCarouselItem
                Description="最后，扎扎师吴迪！"
                Foreground="{StaticResource DarkTextGradient}"
                Header="此版本名称：扎扎师（ZazaDivision）"
                Id="ZaZa"
                ImageUrl="ms-appx:///Assets/HeaderCarousel/ZaZa.png" />
        </dev:HeaderCarousel>
        <StackPanel
            Grid.Row="1"
            Padding="12,0"
            Spacing="8">
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="你的游戏" />
            <controls:ItemShow
                Title="示例标题"
                Author="作者名"
                Detail="文本文本文本文本文本文本文本文本文本文本文本文本文本"
                IconSource="ms-appx:///Assets/AppIcon.png"
                Subtitle="副标题" />
        </StackPanel>
    </Grid>
</Page>

