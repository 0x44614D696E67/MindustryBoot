<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MindustryBoot.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MindustryBoot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:MindustryBoot.Views"
    dev:BreadcrumbNavigator.IsHeaderVisible="True"
    mc:Ignorable="d">
    <ScrollView
        Margin="{ThemeResource ContentPageMargin}"
        Padding="{ThemeResource ContentPagePadding}"
        HorizontalAlignment="Stretch"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Margin="10"
            dev:PanelAttach.ChildrenTransitions="Default"
            Spacing="5">
            <dev:SettingsCard
                Command="{x:Bind NavigateToGeneralSettingsCommand}"
                Description="改变你的应用设置"
                Header="通用"
                HeaderIcon="{dev:FontIcon Glyph=&#xE74C;}"
                IsClickEnabled="True" />
            <dev:SettingsCard
                Command="{x:Bind NavigateToThemeSettingsCommand}"
                Description="探索自定义应用外观和行为的不同方式。您可以更改材质、主题、强调色等选项以符合您的风格和偏好。"
                Header="外观与行为"
                HeaderIcon="{dev:FontIcon Glyph=&#xE790;}"
                IsClickEnabled="True" />
            <dev:SettingsCard
                Command="{x:Bind NavigateToAboutUsSettingsCommand}"
                Description="关于 MindustryBoot 和开发者"
                Header="关于我们"
                HeaderIcon="{dev:FontIcon Glyph=&#xE946;}"
                IsClickEnabled="True" />

        </StackPanel>
    </ScrollView>
</Page>

