<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MindustryBoot.Views.GeneralSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="using:MindustryBoot.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MindustryBoot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:MindustryBoot.Views"
    dev:BreadcrumbNavigator.IsHeaderVisible="True"
    mc:Ignorable="d">
    <ScrollView
        Margin="{ThemeResource ContentPageMargin}"
        Padding="{ThemeResource ContentPagePadding}"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Margin="10"
            dev:PanelAttach.ChildrenTransitions="Default"
            Spacing="5">

            <dev:SettingsCard
                Description="在登录 Windows 时自动启动应用"
                Header="自启动"
                HeaderIcon="{dev:FontIcon Glyph=&#xE7E8;}">
                <ToggleSwitch
                    IsOn="{x:Bind dev:StartupHelper.IsAppStartupWithWindowsForXamlBindingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    OffContent="已禁用"
                    OnContent="已启用" />
            </dev:SettingsCard>

        </StackPanel>
    </ScrollView>
</Page>

