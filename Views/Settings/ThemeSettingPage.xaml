<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="MindustryBoot.Views.ThemeSettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dev="using:DevWinUI"
    xmlns:local="using:MindustryBoot"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:MindustryBoot.Views"
    dev:BreadcrumbNavigator.IsHeaderVisible="True"
    mc:Ignorable="d">
    <ScrollView
        Margin="{ThemeResource ContentPageMargin}"
        Padding="{ThemeResource ContentPagePadding}"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            Margin="10"
            dev:PanelAttach.ChildrenTransitions="Default"
            Spacing="5">
            <dev:SettingsCard
                Description="选择适合您心情和偏好的主题。您可以从深色、浅色或系统主题中进行选择。"
                Header="应用主题"
                HeaderIcon="{dev:FontIcon Glyph=&#xE793;}">
                <ComboBox dev:ThemeServiceAttach.ThemeService="{x:Bind local:App.Current.ThemeService}">
                    <ComboBoxItem Content="浅色" Tag="Light" />
                    <ComboBoxItem Content="深色" Tag="Dark" />
                    <ComboBoxItem Content="默认" Tag="Default" />
                </ComboBox>
            </dev:SettingsCard>
            <dev:SettingsCard
                Description="更改应用程序后面的背景材料外观。您可以从云母、亚克力或透明选项中选择。"
                Header="背景材质"
                HeaderIcon="{dev:FontIcon Glyph=&#xE81E;}">
                <ComboBox dev:ThemeServiceAttach.ThemeService="{x:Bind local:App.Current.ThemeService}">
                    <ComboBoxItem Content="Mica" Tag="Mica" />
                    <ComboBoxItem Content="Mica Alt" Tag="MicaAlt" />
                    <ComboBoxItem Content="Acrylic" Tag="Acrylic" />
                    <ComboBoxItem Content="Acrylic Thin" Tag="AcrylicThin" />
                </ComboBox>
            </dev:SettingsCard>
            <dev:SettingsCard
                Description="应用程序颜色与 Windows 强调色同步。您可以点击此卡片打开 Windows 强调色设置。"
                Header="更改 Windows 强调色"
                HeaderIcon="{dev:FontIcon Glyph=&#xE790;}"
                IsClickEnabled="True"
                LaunchUri="ms-settings:colors" />
        </StackPanel>
    </ScrollView>
</Page>

